  "params": [
    {
      "name": "passengerPick",
      "select": {
        "type": "point",
        "fields": [
          "passenger_type"
        ]
      },
      "bind": "legend"
    }
  ],
  "mark": {
    "type": "circle",
    "size": 150,
    "opacity": 0.9
  },
  "encoding": {
    "y": {
      "field": "airport",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },
    "x": {
      "field": "passengers_million",
      "type": "quantitative",
      "title": "Passengers (million)"
    },
    "color": {
      "field": "passenger_type",
      "type": "nominal",
      "title": "Click legend",
      "scale": {
        "range": [
          "#244c63",
          "#bd6735"
        ]
      }
    },
    "opacity": {
      "condition": {
        "param": "passengerPick",
        "value": 0.9
      },
      "value": 0.18
    },
    "tooltip": [
      {
        "field": "airport"
      },
      {
        "field": "passenger_type"
      },
      {
        "field": "passengers_million",
        "title": "Passengers (m)",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "orient": "bottom"
    }
  }
}