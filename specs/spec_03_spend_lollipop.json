{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Simple bar chart showing tourism spending by traveller type.",
  "width": 520,
  "height": 260,
  "data": {
    "values": [
      {"traveller_type": "All travellers", "spend_aud_billion": 192.4, "spending_growth_percent": 7.0},
      {"traveller_type": "Domestic overnight", "spend_aud_billion": 106.7, "spending_growth_percent": -1.9},
      {"traveller_type": "Domestic day", "spend_aud_billion": 46.4, "spending_growth_percent": 19.0},
      {"traveller_type": "International", "spend_aud_billion": 39.2, "spending_growth_percent": 19.0}
    ]
  },
  "mark": {"type": "bar", "cornerRadiusEnd": 5},
  "encoding": {
    "y": {
      "field": "traveller_type",
      "type": "nominal",
      "title": null,
      "sort": "-x"
    },
    "x": {
      "field": "spend_aud_billion",
      "type": "quantitative",
      "title": "Spend (AUD billion)"
    },
    "color": {
      "field": "spending_growth_percent",
      "type": "quantitative",
      "title": "Growth (%)"
    },
    "tooltip": [
      {"field": "traveller_type", "type": "nominal", "title": "Traveller type"},
      {"field": "spend_aud_billion", "type": "quantitative", "title": "Spend (AUD billion)", "format": ".1f"},
      {"field": "spending_growth_percent", "type": "quantitative", "title": "Spending growth (%)", "format": ".1f"}
    ]
  },
  "config": {
    "view": {"stroke": null},
    "axis": {"labelFontSize": 12, "titleFontSize": 12},
    "legend": {"labelFontSize": 11, "titleFontSize": 11}
  }
}
